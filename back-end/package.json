{
  "name": "back-end",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:create": "ts-node -r tsconfig-paths/register src/db/scripts/create-db.ts",
    "db:drop": "ts-node src/db/scripts/drop-db.ts",
    "db:migrate": "ts-node src/db/scripts/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/db/scripts/seed.ts",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "camelcase-keys": "^9.1.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "db-local": "^3.1.0",
    "decamelize": "^6.0.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.14.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "module-alias": "^2.2.3",
    "standard": "^17.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
